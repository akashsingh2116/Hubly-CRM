# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/hubly

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ── File uploads ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Email (optional — for password reset / notifications) ─────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@hubly.io

# ── Slack (optional — for webhook notifications) ──────────────────────────
SLACK_WEBHOOK_URL=
